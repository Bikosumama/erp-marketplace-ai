PORT=5000
NODE_ENV=development

# PostgreSQL — set DATABASE_URL for Render (takes precedence over individual DB_* vars)
# Example Render External URL: postgres://user:password@host/dbname
DATABASE_URL=
# Optional: set to "disable" to skip SSL (e.g. local dev with no SSL)
# PGSSLMODE=disable

# Legacy individual DB vars (used only if DATABASE_URL is not set)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=erp_marketplace_ai
DB_PASSWORD=postgres
DB_PORT=5432

# JWT secret — use a long random string in production
JWT_SECRET=your_jwt_secret_key_here_change_in_production
TRENDYOL_API_KEY=
HEPSIBURADA_API_KEY=
AMAZON_API_KEY=
N11_API_KEY=
IDEFIX_API_KEY=
PAZARAMA_API_KEY=
REDIS_HOST=localhost
REDIS_PORT=6379
LOG_LEVEL=info
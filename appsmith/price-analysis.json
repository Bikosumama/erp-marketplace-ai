{\n  \"appName\": \"ERP Marketplace AI\",\n  \"pageName\": \"PriceAnalysis\",\n  \"widgets\": [\n    {\n      \"type\": \"Text\",\n      \"name\": \"Title\",\n      \"text\": \"AI Fiyat Analizi ve Dinamik Fiyatlandırma\",\n      \"fontSize\": \"24px\",\n      \"fontWeight\": \"bold\"\n    },\n    {\n      \"type\": \"Select\",\n      \"name\": \"ProductFilterSelect\",\n      \"label\": \"Ürün Seç\",\n      \"options\": \"{{products}}\"\n    },\n    {\n      \"type\": \"Button\",\n      \"name\": \"AnalyzeButton\",\n      \"label\": \"Analiz Et\"\n    },\n    {\n      \"type\": \"Container\",\n      \"name\": \"AnalysisResultsContainer\",\n      \"children\": [\n        {\n          \"type\": \"Card\",\n          \"name\": \"CurrentPriceCard\",\n          \"title\": \"Mevcut Fiyat\",\n          \"value\": \"{{analysis.currentPrice}} ₺\"\n        },\n        {\n          \"type\": \"Card\",\n          \"name\": \"RecommendedPriceCard\",\n          \"title\": \"Önerilen Fiyat\",\n          \"value\": \"{{analysis.recommendedPrice}} ₺\"\n        },\n        {\n          \"type\": \"Card\",\n          \"name\": \"PriceDifferenceCard\",\n          \"title\": \"Fiyat Farkı\",\n          \"value\": \"{{analysis.priceDifference}} ₺\"\n        },\n        {\n          \"type\": \"Card\",\n          \"name\": \"ProfitMarginCard\",\n          \"title\": \"Kar Marjı\",\n          \"value\": \"{{analysis.profitMargin}}%\"\n        }\n      ]\n    },\n    {\n      \"type\": \"Chart\",\n      \"name\": \"CompetitorPricesChart\",\n      \"title\": \"Rakip Fiyatları\",\n      \"chartType\": \"bar\",\n      \"dataSource\": \"{{analysis.competitorPrices}}\"\n    },\n    {\n      \"type\": \"Chart\",\n      \"name\": \"PriceHistoryChart\",\n      \"title\": \"Fiyat Geçmişi\",\n      \"chartType\": \"line\",\n      \"dataSource\": \"{{analysis.priceHistory}}\"\n    },\n    {\n      \"type\": \"Table\",\n      \"name\": \"CostBreakdownTable\",\n      \"title\": \"Maliyet Dökümü\",\n      \"columns\": [\n        { \"key\": \"description\", \"header\": \"Açıklama\" },\n        { \"key\": \"amount\", \"header\": \"Tutar\" },\n        { \"key\": \"percentage\", \"header\": \"Yüzde\" }\n      ],\n      \"rows\": \"{{analysis.costBreakdown}}\"\n    },\n    {\n      \"type\": \"Modal\",\n      \"name\": \"PricingRulesModal\",\n      \"title\": \"Fiyatlandırma Kuralları\",\n      \"children\": [\n        {\n          \"type\": \"TextInput\",\n          \"name\": \"MinimumProfitMarginInput\",\n          \"label\": \"Minimum Kar Marjı (%)\",\n          \"placeholder\": \"Örn: 20\"\n        },\n        {\n          \"type\": \"TextInput\",\n          \"name\": \"MarkupPercentageInput\",\n          \"label\": \"Fiyat Artış Yüzdesi (%)\",\n          \"placeholder\": \"Örn: 5\"\n        },\n        {\n          \"type\": \"Select\",\n          \"name\": \"MarketplaceRuleSelect\",\n          \"label\": \"Pazaryeri Seç\",\n          \"options\": [\n            { \"label\": \"Trendyol\", \"value\": \"trendyol\" },\n            { \"label\": \"Hepsiburada\", \"value\": \"hepsiburada\" },\n            { \"label\": \"Amazon Türkiye\", \"value\": \"amazon\" },\n            { \"label\": \"N11\", \"value\": \"n11\" },\n            { \"label\": \"İdefix\", \"value\": \"idefix\" },\n            { \"label\": \"Pazarama\", \"value\": \"pazarama\" }\n          ]\n        },\n        {\n          \"type\": \"Button\",\n          \"name\": \"SaveRuleButton\",\n          \"label\": \"Kuralı Kaydet\"\n        }\n      ]\n    }\n  ]\n}
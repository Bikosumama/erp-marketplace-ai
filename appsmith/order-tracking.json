{"appName": "ERP Marketplace AI", "pageName": "OrderTracking", "widgets": [{"type": "Text", "name": "Title", "text": "Sipariş Takibi", "fontSize": "24px", "fontWeight": "bold"}, {"type": "Select", "name": "MarketplaceFilterSelect", "label": "Pazaryeri Filtrele", "options": [{"label": "Tüm Pazaryerleri", "value": "all"}, {"label": "Trendyol", "value": "trendyol"}, {"label": "Hepsiburada", "value": "hepsiburada"}, {"label": "Amazon Türkiye", "value": "amazon"}, {"label": "N11", "value": "n11"}, {"label": "İdefix", "value": "idefix"}, {"label": "Pazarama", "value": "pazarama"}]}, {"type": "Select", "name": "StatusFilterSelect", "label": "Durum Filtrele", "options": [{"label": "Tüm Durumlar", "value": "all"}, {"label": "Beklemede", "value": "pending"}, {"label": "Onaylandı", "value": "confirmed"}, {"label": "Hazırlanıyor", "value": "preparing"}, {"label": "Gönderildi", "value": "shipped"}, {"label": "Teslim Edildi", "value": "delivered"}, {"label": "İptal", "value": "cancelled"}]}, {"type": "Table", "name": "OrdersTable", "title": "Siparişler", "columns": [{"key": "id", "header": "Sipariş ID"}, {"key": "marketplace", "header": "Pazaryeri"}, {"key": "date", "header": "Tarih"}, {"key": "customer", "header": "Müşteri"}, {"key": "amount", "header": "Tutar"}, {"key": "status", "header": "Durum"}, {"key": "actions", "header": "İşlemler"}], "rows": "{{orders}}"}, {"type": "Modal", "name": "OrderDetailModal", "title": "Sipariş Detayı", "children": [{"type": "Text", "name": "OrderIdText", "text": "Sipariş ID: {{selectedOrder.id}}"}, {"type": "Text", "name": "OrderStatusText", "text": "Durum: {{selectedOrder.status}}"}, {"type": "Text", "name": "OrderAmountText", "text": "Tutar: {{selectedOrder.amount}} ₺"}, {"type": "Table", "name": "OrderItemsTable", "title": "Sipariş Ürünleri", "columns": [{"key": "product_name", "header": "Ürün"}, {"key": "quantity", "header": "Miktar"}, {"key": "unit_price", "header": "Birim Fiyat"}, {"key": "total_price", "header": "Toplam Fiyat"}], "rows": "{{selectedOrder.items}}"}]}]}